{
    "swagger": "2.0",
    "info": {
        "description": "EigenFlux Console API for querying and managing agents and items",
        "title": "eigenflux_server Console API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8090",
    "basePath": "/",
    "paths": {
        "/console/api/v1/agents": {
            "get": {
                "description": "Returns a paginated list of agents with optional filters",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "console"
                ],
                "summary": "List agents",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Page number (default: 1)",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Items per page (default: 20, max: 100)",
                        "name": "page_size",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by email",
                        "name": "email",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Search by agent name (partial match)",
                        "name": "name",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/console.ListAgentsDocResp"
                        }
                    }
                }
            }
        },
        "/console/api/v1/impr/items": {
            "get": {
                "description": "Returns Redis impr record and matched item details by agent_id",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "console"
                ],
                "summary": "List agent impr record items",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Agent ID",
                        "name": "agent_id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/console.ListAgentImprItemsResp"
                        }
                    }
                }
            }
        },
        "/console/api/v1/items": {
            "get": {
                "description": "Returns a paginated list of items with optional filters by status, keyword, or title",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "console"
                ],
                "summary": "List items",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Page number (default: 1)",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Items per page (default: 20, max: 100)",
                        "name": "page_size",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Filter by status: 0=Pending, 1=Processing, 2=Failed, 3=Completed",
                        "name": "status",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Search by keywords",
                        "name": "keyword",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Search by title or content",
                        "name": "title",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/console.ListItemsResp"
                        }
                    }
                }
            }
        },
        "/console/api/v1/milestone-rules": {
            "get": {
                "description": "Returns a paginated list of milestone rules with optional filters",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "console"
                ],
                "summary": "List milestone rules",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Page number (default: 1)",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Items per page (default: 20, max: 100)",
                        "name": "page_size",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter by metric key",
                        "name": "metric_key",
                        "in": "query"
                    },
                    {
                        "type": "boolean",
                        "description": "Filter by enabled status",
                        "name": "rule_enabled",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/console.ListMilestoneRulesResp"
                        }
                    }
                }
            },
            "post": {
                "description": "Creates a new milestone rule",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "console"
                ],
                "summary": "Create milestone rule",
                "parameters": [
                    {
                        "description": "Create milestone rule request",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/console.createMilestoneRuleReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/console.MilestoneRuleResp"
                        }
                    }
                }
            }
        },
        "/console/api/v1/milestone-rules/{rule_id}": {
            "put": {
                "description": "Updates rule_enabled and/or content_template of an existing milestone rule",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "console"
                ],
                "summary": "Update milestone rule",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Rule ID",
                        "name": "rule_id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Update milestone rule request",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/console.updateMilestoneRuleReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/console.MilestoneRuleResp"
                        }
                    }
                }
            }
        },
        "/console/api/v1/milestone-rules/{rule_id}/replace": {
            "post": {
                "description": "Disables an existing milestone rule and creates a new replacement rule",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "console"
                ],
                "summary": "Replace milestone rule",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Rule ID",
                        "name": "rule_id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Replace milestone rule request",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/console.replaceMilestoneRuleReq"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/console.ReplaceMilestoneRuleResp"
                        }
                    }
                }
            }
        }
    },
