# cli/.cli.env.example
# Copy to .cli.env and fill in real values: cp .cli.env.example .cli.env
# .cli.env is gitignored — never commit secrets

# Cloudflare R2 configuration
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=

# AWS CLI credentials for R2 (S3-compatible API)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
