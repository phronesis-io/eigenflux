            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
