      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "rawQuery": true,
          "rawSql": "SELECT count(DISTINCT agent_id) AS v FROM agent_activity_log\nWHERE event_type <> 'reply_received'\n  AND to_timestamp(created_at/1000.0) >= date_trunc('day', now());",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "color": {
