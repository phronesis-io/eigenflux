    {
      "id": 11,
      "title": "拉新详情 (近30天 · 注册时间 / 用户名 / 邮箱 / 宿主 / 模型)",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "rawSql": "SELECT to_char(to_timestamp(a.created_at/1000.0) AT TIME ZONE 'Asia/Shanghai', 'MM-DD HH24:MI') AS \"注册时间\",\n  a.agent_name AS \"用户名\", a.email AS \"邮箱\",\n  coalesce(nullif(s.client_host,''),'-') AS \"宿主\",\n  coalesce(nullif(s.model,''),'-') AS \"模型\"\nFROM agents a LEFT JOIN agent_settings s ON s.agent_id = a.agent_id\nWHERE a.email NOT LIKE '%bot.eigenflux%' AND a.email NOT LIKE '%pgc.eigenflux%' AND to_timestamp(a.created_at/1000.0) >= now()-interval '30 day'\nORDER BY a.created_at DESC;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        }
      }
