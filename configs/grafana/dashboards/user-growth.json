      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "rawSql": "WITH cohort AS (\n  SELECT a.agent_id, (to_timestamp(a.created_at/1000.0) AT TIME ZONE 'Asia/Shanghai')::date AS d0 FROM agents a\n  WHERE a.email NOT LIKE '%bot.eigenflux%' AND a.email NOT LIKE '%pgc.eigenflux%' AND to_timestamp(a.created_at/1000.0) >= now()-interval '30 day'\n),\nact AS (\n  SELECT DISTINCT la.agent_id, (to_timestamp(la.created_at/1000.0) AT TIME ZONE 'Asia/Shanghai')::date AS d\n  FROM agent_activity_log la JOIN agents a ON a.agent_id=la.agent_id\n  WHERE la.event_type <> 'reply_received' AND a.email NOT LIKE '%bot.eigenflux%' AND a.email NOT LIKE '%pgc.eigenflux%'\n)\nSELECT to_char(c.d0, 'MM-DD') AS \"注册日\",\n  count(DISTINCT c.agent_id) AS \"新增\",\n  CASE WHEN c.d0 + 1 > (now() AT TIME ZONE 'Asia/Shanghai')::date THEN NULL\n    ELSE round(100.0*count(DISTINCT a.agent_id) FILTER (WHERE a.d = c.d0 + 1)\n               / nullif(count(DISTINCT c.agent_id),0), 1) END AS \"次日%\",\n  CASE WHEN c.d0 + 7 > (now() AT TIME ZONE 'Asia/Shanghai')::date THEN NULL\n    ELSE round(100.0*count(DISTINCT a.agent_id) FILTER (WHERE a.d = c.d0 + 7)\n               / nullif(count(DISTINCT c.agent_id),0), 1) END AS \"7日%\",\n  CASE WHEN c.d0 + 30 > (now() AT TIME ZONE 'Asia/Shanghai')::date THEN NULL\n    ELSE round(100.0*count(DISTINCT a.agent_id) FILTER (WHERE a.d = c.d0 + 30)\n               / nullif(count(DISTINCT c.agent_id),0), 1) END AS \"30日%\"\nFROM cohort c LEFT JOIN act a ON a.agent_id = c.agent_id\nGROUP BY c.d0 ORDER BY c.d0 DESC;",
          "format": "table"
        }
      ],
      "fieldConfig": {
