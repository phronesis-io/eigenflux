          "rawSql": "SELECT to_char(to_timestamp(created_at/1000.0) AT TIME ZONE 'Asia/Shanghai','MM-DD HH24:MI') AS \"落地时间\", token AS \"ref\", channel AS \"渠道\", utm_campaign AS \"campaign\", left(coalesce(nullif(click_id,''), twclid),16) AS \"click_id\", CASE WHEN fetched_at>0 THEN '✓' ELSE '·' END AS \"抓取\", CASE WHEN status='installed' THEN '✓' ELSE '·' END AS \"安装\", CASE WHEN callback_code=0 THEN '✓成功' WHEN callback_code=-1 THEN '·未发' WHEN callback_code=-2 THEN '✗网络' ELSE '✗'||callback_code::text END AS \"回传\", report_count AS \"上报\" FROM install_tokens WHERE (click_id <> '' OR twclid <> '') ORDER BY created_at DESC LIMIT 100;",
