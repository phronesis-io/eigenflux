    {
      "id": 9,
      "title": "次日留存率趋势",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 6,
        "y": 24
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "rawSql": "WITH cohort AS (\n  SELECT a.agent_id, (to_timestamp(a.created_at/1000.0) AT TIME ZONE 'Asia/Shanghai')::date AS d0 FROM agents a\n  WHERE a.email NOT LIKE '%bot.eigenflux%' AND a.email NOT LIKE '%pgc.eigenflux%' AND to_timestamp(a.created_at/1000.0) >= now()-interval '30 day'\n),\nact AS (\n  SELECT DISTINCT la.agent_id, (to_timestamp(la.created_at/1000.0) AT TIME ZONE 'Asia/Shanghai')::date AS d\n  FROM agent_activity_log la JOIN agents a ON a.agent_id=la.agent_id\n  WHERE la.event_type <> 'reply_received' AND a.email NOT LIKE '%bot.eigenflux%' AND a.email NOT LIKE '%pgc.eigenflux%'\n)\nSELECT c.d0 AS time,\n  round(100.0*count(DISTINCT a.agent_id) FILTER (WHERE a.d = c.d0 + 1)\n        / nullif(count(DISTINCT c.agent_id),0), 1) AS \"次日留存%\"\nFROM cohort c LEFT JOIN act a ON a.agent_id = c.agent_id\nWHERE c.d0 + 1 <= (now() AT TIME ZONE 'Asia/Shanghai')::date\nGROUP BY 1 ORDER BY 1;",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "auto",
            "barAlignment": 0,
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 10,
      "title": "留存三角 (Cohort · 按注册日, 未到期显示暂无数据)",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "rawSql": "WITH cohort AS (\n  SELECT a.agent_id, (to_timestamp(a.created_at/1000.0) AT TIME ZONE 'Asia/Shanghai')::date AS d0 FROM agents a\n  WHERE a.email NOT LIKE '%bot.eigenflux%' AND a.email NOT LIKE '%pgc.eigenflux%' AND to_timestamp(a.created_at/1000.0) >= now()-interval '30 day'\n),\nact AS (\n  SELECT DISTINCT la.agent_id, (to_timestamp(la.created_at/1000.0) AT TIME ZONE 'Asia/Shanghai')::date AS d\n  FROM agent_activity_log la JOIN agents a ON a.agent_id=la.agent_id\n  WHERE la.event_type <> 'reply_received' AND a.email NOT LIKE '%bot.eigenflux%' AND a.email NOT LIKE '%pgc.eigenflux%'\n)\nSELECT to_char(c.d0, 'MM-DD') AS \"注册日\",\n  count(DISTINCT c.agent_id) AS \"新增\",\n  CASE WHEN c.d0 + 1 > (now() AT TIME ZONE 'Asia/Shanghai')::date THEN NULL\n    ELSE round(100.0*count(DISTINCT a.agent_id) FILTER (WHERE a.d = c.d0 + 1)\n               / nullif(count(DISTINCT c.agent_id),0), 1) END AS \"次日%\",\n  CASE WHEN c.d0 + 7 > (now() AT TIME ZONE 'Asia/Shanghai')::date THEN NULL\n    ELSE round(100.0*count(DISTINCT a.agent_id) FILTER (WHERE a.d = c.d0 + 7)\n               / nullif(count(DISTINCT c.agent_id),0), 1) END AS \"7日%\",\n  CASE WHEN c.d0 + 30 > (now() AT TIME ZONE 'Asia/Shanghai')::date THEN NULL\n    ELSE round(100.0*count(DISTINCT a.agent_id) FILTER (WHERE a.d = c.d0 + 30)\n               / nullif(count(DISTINCT c.agent_id),0), 1) END AS \"30日%\"\nFROM cohort c LEFT JOIN act a ON a.agent_id = c.agent_id\nGROUP BY c.d0 ORDER BY c.d0 DESC;",
          "format": "table"
        }
      ],
