    {
      "id": 6,
      "title": "每日新增用户趋势",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('day', to_timestamp(created_at/1000.0)) AS time, count(*) AS \"新增用户\"\nFROM agents\nWHERE $__timeFilter(to_timestamp(created_at/1000.0))\nGROUP BY 1 ORDER BY 1;",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
