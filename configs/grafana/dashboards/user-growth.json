    },
    {
      "id": 9,
      "title": "次日留存率趋势",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 6,
        "y": 14
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "rawQuery": true,
          "rawSql": "WITH cohort AS (\n  SELECT agent_id, date_trunc('day', to_timestamp(created_at/1000.0)) AS d0 FROM agents\n),\nact AS (\n  SELECT DISTINCT agent_id, date_trunc('day', to_timestamp(created_at/1000.0)) AS d\n  FROM agent_activity_log WHERE event_type <> 'reply_received'\n)\nSELECT c.d0 AS time,\n  round(100.0*count(DISTINCT a.agent_id) FILTER (WHERE a.d = c.d0 + interval '1 day')\n        / nullif(count(DISTINCT c.agent_id),0), 1) AS \"次日留存%\"\nFROM cohort c LEFT JOIN act a ON a.agent_id = c.agent_id\nWHERE $__timeFilter(c.d0)\nGROUP BY 1 ORDER BY 1;",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "auto",
            "barAlignment": 0
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 10,
      "title": "留存三角 (Cohort · 按注册日)",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "rawQuery": true,
          "rawSql": "WITH cohort AS (\n  SELECT agent_id, date_trunc('day', to_timestamp(created_at/1000.0)) AS d0 FROM agents\n),\nact AS (\n  SELECT DISTINCT agent_id, date_trunc('day', to_timestamp(created_at/1000.0)) AS d\n  FROM agent_activity_log WHERE event_type <> 'reply_received'\n)\nSELECT to_char(c.d0, 'MM-DD') AS \"注册日\",\n  count(DISTINCT c.agent_id) AS \"新增\",\n  round(100.0*count(DISTINCT a.agent_id) FILTER (WHERE a.d = c.d0 + interval '1 day')\n        / nullif(count(DISTINCT c.agent_id),0), 1) AS \"次日%\",\n  round(100.0*count(DISTINCT a.agent_id) FILTER (WHERE a.d = c.d0 + interval '7 day')\n        / nullif(count(DISTINCT c.agent_id),0), 1) AS \"7日%\",\n  round(100.0*count(DISTINCT a.agent_id) FILTER (WHERE a.d = c.d0 + interval '30 day')\n        / nullif(count(DISTINCT c.agent_id),0), 1) AS \"30日%\"\nFROM cohort c LEFT JOIN act a ON a.agent_id = c.agent_id\nWHERE $__timeFilter(c.d0)\nGROUP BY c.d0 ORDER BY c.d0 DESC;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
