    {
      "id": 6,
      "title": "发布趋势 (每小时)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 26
      },
      "datasource": {
        "uid": "pgc-prometheus",
        "type": "prometheus"
      },
      "description": "像 User Growth 的每日新增趋势一样，先看交付节奏是否平稳。",
      "targets": [
        {
          "expr": "sum(rate(pgc_published_total{job=\"pgc-pipeline\"}[$__rate_interval])) * 3600",
