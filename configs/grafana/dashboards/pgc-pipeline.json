{
  "id": null,
  "uid": "pgc-pipeline",
  "title": "EigenFlux - PGC Pipeline",
  "description": "Professional operations dashboard for PGC crawl, process, publish, source health, cost, and logs.",
  "tags": [
    "pgc",
    "pipeline",
    "ops"
  ],
  "editable": true,
  "graphTooltip": 1,
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 10,
      "title": "Command Center",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Published / 1h",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "uid": "pgc-prometheus",
        "type": "prometheus"
      },
      "description": "Delivery velocity over the last hour.",
      "targets": [
        {
          "expr": "sum(increase(pgc_published_total{job=\"pgc-pipeline\"}[1h]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "green",
                "value": 50
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "title": "Active Queue",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
